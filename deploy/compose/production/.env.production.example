# Production-pilot Compose environment template.
# Copy to an untracked file and replace placeholders before use.

COMPOSE_PROJECT_NAME=siem

# Production-pilot images are pinned to locally validated immutable digests.
GRAFANA_IMAGE=grafana/grafana@sha256:5dad0df181cb644a14e13617b913b261a54f7d4fd4510721dba420929f35bea2
LOKI_IMAGE=grafana/loki@sha256:191d4fdfb7264f16989f0a57f320872620a5a7c2ceeec6229212c4190ec49b86
TEMPO_IMAGE=grafana/tempo@sha256:1ce31d6d7ffab62189685e8c47881d4a561c5d38bd0dbd66e40ca83cef07923d
MIMIR_IMAGE=grafana/mimir@sha256:2b49dca9ee4a121cc39bfb1e6f661c1e975cf52a7d14cc6b90de2e5e29caa92e
PROMETHEUS_IMAGE=prom/prometheus@sha256:69f5241418838263316593f7274a304b095c40bcf22e57272865da91bd60a8ac
ALLOY_IMAGE=grafana/alloy@sha256:41c41849989b7e054ccbadc17938ee1e5592fe26bfbc56ef3ffc109c0b0b2739
VECTOR_IMAGE=timberio/vector@sha256:6a56f8ee78e014d53a32fd7c6f6be9c18244fe861d938932fad8d6e65d3f5926
TELEMETRYGEN_IMAGE=ghcr.io/open-telemetry/opentelemetry-collector-contrib/telemetrygen@sha256:5bc9b76bf67af176f037ba2fbc5db72d3d34f8fe96f61b0b2d1c1b23a4497f68
BUSYBOX_IMAGE=busybox@sha256:fd8d9aa63ba2f0982b5304e1ee8d3b90a210bc1ffb5314d980eb6962f1a9715d
CADDY_IMAGE=caddy@sha256:77c07d5ebfa5be9fd6c820d2094ae662c9e7eeb9bf98346b7f639900263ee2a2

GRAFANA_HTTP_BIND_ADDRESS=127.0.0.1
LOKI_HTTP_BIND_ADDRESS=127.0.0.1
TEMPO_HTTP_BIND_ADDRESS=127.0.0.1
TEMPO_OTLP_GRPC_BIND_ADDRESS=127.0.0.1
TEMPO_OTLP_HTTP_BIND_ADDRESS=127.0.0.1
MIMIR_HTTP_BIND_ADDRESS=127.0.0.1
PROMETHEUS_HTTP_BIND_ADDRESS=127.0.0.1
ALLOY_HTTP_BIND_ADDRESS=127.0.0.1
SIEM_COLLECTOR_HTTP_BIND_ADDRESS=127.0.0.1
SIEM_COLLECTOR_METRICS_BIND_ADDRESS=127.0.0.1
SIEM_HTTP_EVENT_BIND_ADDRESS=127.0.0.1

# Expose syslog only after host firewall rules restrict approved sender networks.
SIEM_SYSLOG_TCP_BIND_ADDRESS=127.0.0.1
SIEM_SYSLOG_UDP_BIND_ADDRESS=127.0.0.1

# Public production-pilot edge surface.
SIEM_EDGE_HTTPS_BIND_ADDRESS=0.0.0.0
SIEM_EDGE_HTTPS_PORT=8443

# Keep production data outside the Git worktree.
SIEM_INGEST_DIR=/srv/siem/ingest
