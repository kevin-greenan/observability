# Local lab defaults only. Do not use this file as a production secret store.
COMPOSE_PROJECT_NAME=lgtm

GRAFANA_IMAGE=grafana/grafana:latest
LOKI_IMAGE=grafana/loki:latest
TEMPO_IMAGE=grafana/tempo:latest
MIMIR_IMAGE=grafana/mimir:latest
PROMETHEUS_IMAGE=prom/prometheus:latest
ALLOY_IMAGE=grafana/alloy:latest
VECTOR_IMAGE=timberio/vector:0.49.0-debian
TELEMETRYGEN_IMAGE=ghcr.io/open-telemetry/opentelemetry-collector-contrib/telemetrygen:latest
BUSYBOX_IMAGE=busybox:latest
CADDY_IMAGE=caddy:2-alpine

GRAFANA_HTTP_BIND_ADDRESS=127.0.0.1
GRAFANA_HTTP_PORT=3000
LOKI_HTTP_BIND_ADDRESS=127.0.0.1
LOKI_HTTP_PORT=3100
TEMPO_HTTP_BIND_ADDRESS=127.0.0.1
TEMPO_HTTP_PORT=3200
TEMPO_OTLP_GRPC_BIND_ADDRESS=127.0.0.1
TEMPO_OTLP_GRPC_PORT=4317
TEMPO_OTLP_HTTP_BIND_ADDRESS=127.0.0.1
TEMPO_OTLP_HTTP_PORT=4318
MIMIR_HTTP_BIND_ADDRESS=127.0.0.1
MIMIR_HTTP_PORT=9009
PROMETHEUS_HTTP_BIND_ADDRESS=127.0.0.1
PROMETHEUS_HTTP_PORT=9090
ALLOY_HTTP_BIND_ADDRESS=127.0.0.1
ALLOY_HTTP_PORT=12345
SIEM_COLLECTOR_HTTP_BIND_ADDRESS=127.0.0.1
SIEM_COLLECTOR_HTTP_PORT=8686
SIEM_COLLECTOR_METRICS_BIND_ADDRESS=127.0.0.1
SIEM_COLLECTOR_METRICS_PORT=9598
SIEM_INGEST_DIR=./ingest
SIEM_HTTP_EVENT_BIND_ADDRESS=127.0.0.1
SIEM_HTTP_EVENT_PORT=8088
SIEM_HTTP_EVENT_TOKEN=change-me # local-only placeholder; rotate before non-local use
SIEM_SYSLOG_TCP_BIND_ADDRESS=127.0.0.1
SIEM_SYSLOG_TCP_PORT=5514
SIEM_SYSLOG_UDP_BIND_ADDRESS=127.0.0.1
SIEM_SYSLOG_UDP_PORT=5514
SIEM_EDGE_HTTPS_BIND_ADDRESS=0.0.0.0
SIEM_EDGE_HTTPS_PORT=8443

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin # local-only placeholder; use SSO and managed secrets for production
