# Local lab defaults only. Do not use this file as a production secret store.
COMPOSE_PROJECT_NAME=lgtm

GRAFANA_VERSION=latest
LOKI_VERSION=latest
TEMPO_VERSION=latest
MIMIR_VERSION=latest
PROMETHEUS_VERSION=latest
ALLOY_VERSION=latest
VECTOR_VERSION=0.49.0-debian
TELEMETRYGEN_VERSION=latest
BUSYBOX_VERSION=latest
CADDY_VERSION=2-alpine

GRAFANA_HTTP_BIND_ADDRESS=127.0.0.1
GRAFANA_HTTP_PORT=3000
LOKI_HTTP_BIND_ADDRESS=127.0.0.1
LOKI_HTTP_PORT=3100
TEMPO_HTTP_BIND_ADDRESS=127.0.0.1
TEMPO_HTTP_PORT=3200
TEMPO_OTLP_GRPC_BIND_ADDRESS=127.0.0.1
TEMPO_OTLP_GRPC_PORT=4317
TEMPO_OTLP_HTTP_BIND_ADDRESS=127.0.0.1
TEMPO_OTLP_HTTP_PORT=4318
MIMIR_HTTP_BIND_ADDRESS=127.0.0.1
MIMIR_HTTP_PORT=9009
PROMETHEUS_HTTP_BIND_ADDRESS=127.0.0.1
PROMETHEUS_HTTP_PORT=9090
ALLOY_HTTP_BIND_ADDRESS=127.0.0.1
ALLOY_HTTP_PORT=12345
SIEM_COLLECTOR_HTTP_BIND_ADDRESS=127.0.0.1
SIEM_COLLECTOR_HTTP_PORT=8686
SIEM_COLLECTOR_METRICS_BIND_ADDRESS=127.0.0.1
SIEM_COLLECTOR_METRICS_PORT=9598
SIEM_INGEST_DIR=./ingest
SIEM_HTTP_EVENT_BIND_ADDRESS=127.0.0.1
SIEM_HTTP_EVENT_PORT=8088
